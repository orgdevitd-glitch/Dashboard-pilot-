# GEMINI_API_KEY: Required for Gemini AI API calls (if used).
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# OPENAI_API_KEY: Required for OpenAI project analysis.
OPENAI_API_KEY="your_openai_api_key_here"
OPENAI_MODEL="gpt-4o"

# APP_INGEST_TOKEN: Secret token for Bitrix24 to authorize imports.
APP_INGEST_TOKEN="generate_a_secure_token_here"

# APP_URL: The URL where this applet is hosted.
APP_URL="MY_APP_URL"

# Storage configuration
STORAGE_TYPE="json"
DATA_DIR="./data"

# Application Access Protection
# Set either plain text or a SHA-256 hex hash of the password
APP_ACCESS_PASSWORD="your_secure_password_here"
APP_ACCESS_PASSWORD_HASH=""

# Google Sheets CSV fallback configurations
GOOGLE_SHEETS_CSV_URL=""
